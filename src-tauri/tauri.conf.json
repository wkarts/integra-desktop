{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Integra Desktop",
  "version": "0.2.0",
  "identifier": "br.com.wwsoftwares.integra.desktop",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Integra Desktop",
        "width": 1600,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "appimage",
      "deb"
    ],
    "icon": []
  }
}
